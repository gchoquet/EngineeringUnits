{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "src": "../src"
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "memberLayout": "samePage",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md"]
      }
    ],
    "resource": [
      { "files": ["images/**"] }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "EngineeringUnits",
      "_appTitle": "EngineeringUnits API Documentation",
      "_appFooter": "Copyright © 2026 Gary Choquette. MIT License.",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/gchoquet/EngineeringUnits",
        "branch": "main"
      },
      "pdf": false
    },
    "xref": ["https://learn.microsoft.com/en-us/dotnet/.xrefmap.json"]
  }
}
